{
  "index_name": "__INDEX_NAME__",
  "start_urls": [
    {
      "url": "https://sleep1223.github.io/fast-soy-admin-docs/",
      "page_rank": 2
    },
    {
      "url": "https://sleep1223.github.io/fast-soy-admin-docs/en/",
      "page_rank": 1
    }
  ],
  "sitemap_urls": [],
  "stop_urls": [],
  "selectors": {
    "lvl0": {
      "selector": "//*[contains(@class,'VPSidebarItem') and contains(@class,'level-0') and contains(@class,'is-active')]//*[contains(@class,'text')]",
      "type": "xpath",
      "default_value": "FastSoyAdmin",
      "global": true
    },
    "lvl1": ".VPDoc .content h1",
    "lvl2": ".VPDoc .content h2",
    "lvl3": ".VPDoc .content h3",
    "lvl4": ".VPDoc .content h4",
    "lvl5": ".VPDoc .content h5",
    "lvl6": ".VPDoc .content h6",
    "text": ".VPDoc .content p, .VPDoc .content li",
    "lang": {
      "selector": "/html/@lang",
      "type": "xpath",
      "global": true
    }
  },
  "strip_chars": " .,;:#",
  "custom_settings": {
    "separatorsToIndex": "_",
    "attributesForFaceting": ["lang", "language", "version", "type"],
    "attributesToRetrieve": [
      "hierarchy",
      "content",
      "anchor",
      "url",
      "url_without_anchor",
      "type",
      "lang"
    ]
  }
}
